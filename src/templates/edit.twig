{% extends '_layouts/cp' %}

{% set fullPageForm = true %}
{% set crumbs = [
    { label: "Advanced Discounts"|t('advanced-discounts'), url: url('advanced-discounts') },
] %}
{% set title = "Create discount"|t('advanced-discounts') %}
{% import '_includes/forms.twig' as forms %}

{% block actionButton %}
    <button type="submit" class="btn submit">{{ 'Save discount'|t('advanced-discounts') }}</button>
{% endblock %}

{% block content %}
    {{ actionInput('advanced-discounts/manage/save') }}
    {{ redirectInput('advanced-discounts') }}

    {% if coupon.id %}
        <input type="hidden" name="id" value="{{ coupon.id }}">
    {% endif %}

    {{ forms.textField({
        label: "Name"|t('advanced-discounts'),
        id: 'name',
        name: 'name',
        value: coupon.name,
        type: 'text',
        inputAttributes: {
            data: {lpignore: 'true'},
        },
        required: true,
        errors: coupon.getErrors('name'),
    }) }}

    {{ forms.textField({
        label: "Discount code"|t('advanced-discounts'),
        id: 'code',
        name: 'code',
        value: coupon.code,
        type: 'text',
        instructions: "Leave blank to apply to every applicable order (like a sale). Entering a code requires the code to be entered during checkout for the discount to apply."|t('advanced-discounts'),
        inputAttributes: {
            data: {lpignore: 'true'},
        },
        errors: coupon.getErrors('code'),
    }) }}

    {% set triggerCondition %}
        {{ coupon.triggerCondition.getBuilderHtml()|raw }}
    {% endset %}

    {{ forms.field({
        label: 'Conditions'|t('advanced-discounts'),
        instructions: 'Rules that decide when this discount applies.'|t('advanced-discounts'),
        errors: coupon.getErrors('triggerCondition')
    }, triggerCondition) }}

    {% set actionCondition %}
        {{ coupon.actionCondition.getBuilderHtml()|raw }}
    {% endset %}

    {{ forms.field({
        label: 'Action Rules'|t('advanced-discounts'),
        instructions: 'Create rules to apply discounts.'|t('advanced-discounts'),
        errors: coupon.getErrors('actionCondition')
    }, actionCondition) }}
{% endblock %}

{% block details %}
    <div class="meta">
        {{ forms.lightswitchField({
            label: 'Enabled'|t('app'),
            id: 'enabled',
            name: 'enabled',
            on: coupon.enabled,
        }) }}
    </div>
{% endblock %}
