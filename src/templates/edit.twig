{% extends '_layouts/cp' %}

{% set crumbs = [
    { label: "Coupons"|t('coupons'), url: url('coupons') },
] %}
{% set title = "Create Coupon"|t('coupons') %}
{% import '_includes/forms.twig' as forms %}

{% set hiddenInputs %}
    {{ csrfInput() }}
{% endset %}

{% block actionButton %}
    <button type="button" class="btn submit formsubmit" data-form="couponform">{{ 'Save Coupon'|t('coupons') }}</button>
{% endblock %}

{% set content %}
    {% set formAttributes = {
        id: 'couponform',
        method: 'post',
        'accept-charset': 'UTF-8',
        data: {
            saveshortcut: true,
            'confirm-unload': true,
        },
    } %}
    <form {{ attr(formAttributes) }}>
        {{ actionInput('coupons/save-coupon') }}
        {{ redirectInput('coupons') }}
        {{ hiddenInputs }}

        {{ forms.textField({
            label: "Coupon Name"|t('coupons'),
            id: 'name',
            name: 'name',
            value: '',
            type: 'text',
            inputAttributes: {
                data: {lpignore: 'true'},
            },
        }) }}

        {{ forms.textField({
            label: "Coupon Code"|t('coupons'),
            id: 'code',
            name: 'code',
            value: '',
            type: 'text',
            inputAttributes: {
                data: {lpignore: 'true'},
            },
        }) }}

        <hr />

        <h3>{{ 'Select trigger items'|t('coupons') }}</h3>

        {{ forms.selectField({
            label: "Related to"|t('coupons'),
            instructions: "Choose whether all related items, some related items or none of the related items trigger a coupon"|t('coupons'),
            id: 'relatedTo',
            name: 'relatedTo',
            options: relatedTo,
            value: coupon.relatedTo,
        }) }}

        {% set relatedToCondition %}
            {{ coupon.relatedToCondition.getBuilderHtml()|raw }}
        {% endset %}

        {{ forms.field({
            label: 'Match related'|t('coupons'),
            instructions: 'Create rules that allow this coupon to match the order based on related entries.'|t('coupons'),
            errors: coupon.getErrors('relatedToCondition')
        }, relatedToCondition) }}

        {{ forms.selectField({
            label: "Purchasables"|t('coupons'),
            instructions: "Choose whether all purchasables, some purchasables or none of the purchasables trigger a coupon"|t('coupons'),
            id: 'purchasables',
            name: 'purchasables',
            options: purchasables,
            value: coupon.purchasables,
        }) }}

        {% set purchasablesCondition %}
            {{ coupon.purchasablesCondition.getBuilderHtml()|raw }}
        {% endset %}

        {{ forms.field({
            label: 'Match purchasables'|t('coupons'),
            instructions: 'Create rules that allow this coupon to match the order based on purchasables.'|t('coupons'),
            errors: coupon.getErrors('purchasablesCondition')
        }, purchasablesCondition) }}

        <hr />

        <h3>{{ 'Configure conditions'|t('coupons') }}</h3>

        {% set orderCondition %}
            {{ coupon.orderCondition.getBuilderHtml()|raw }}
        {% endset %}

        {{ forms.field({
            label: 'Order conditions'|t('coupons'),
            instructions: 'Create conditions on an order that contains trigger items'|t('coupons'),
            errors: coupon.getErrors('orderCondition')
        }, orderCondition) }}

        <hr />

        <h3>{{ 'Set order actions'|t('coupons') }}</h3>

        {{ forms.selectField({
            label: "Discount Type"|t('coupons'),
            instructions: "Choose whether to give a percentage or flat amount off"|t('coupons'),
            id: 'discountType',
            name: 'discountType',
            options: discountTypes,
            value: coupon.discountType,
        }) }}

        {{ forms.textField({
            label: "Discount amount"|t('coupons'),
            instructions: "The discount amount to apply"|t('coupons'),
            id: 'discountAmount',
            name: 'discountAmount',
            value: coupon.discountAmount,
            type: 'number',
            errors: coupon.getErrors('discountAmount'),
            tip: "Leaving this blank will disable order discounts"|t('coupons'),
        }) }}

        {{ forms.selectField({
            label: "Apply to"|t('coupons'),
            instructions: "Apply the discount to the order, trigger items, or conditional items configured below."|t('coupons'),
            id: 'applyTo',
            name: 'applyTo',
            options: applyTo,
            value: coupon.applyTo,
        }) }}

        {{ forms.textField({
            label: "Item limit"|t('coupons'),
            instructions: "Limit the number of items the discount can be applied to"|t('coupons'),
            id: 'itemLimit',
            name: 'itemLimit',
            value: coupon.itemLimit,
            type: 'number',
            errors: coupon.getErrors('itemLimit'),
            tip: "Leave blank for unlimited amount of items"|t('coupons'),
        }) }}

        {% set applyCondition %}
            {{ coupon.applyCondition.getBuilderHtml()|raw }}
        {% endset %}

        {{ forms.field({
            label: 'Apply condition'|t('coupons'),
            instructions: 'Create rules to match items the discount will be applied to.'|t('coupons'),
            errors: coupon.getErrors('applyCondition'),
        }, applyCondition) }}

        <h3>{{ 'Set shipping actions'|t('coupons') }}</h3>

        {{ forms.selectField({
            label: "Shipping discount Type"|t('coupons'),
            instructions: "Choose whether to give a percentage or flat amount off"|t('coupons'),
            id: 'shippingDiscountType',
            name: 'shippingDiscountType',
            options: discountTypes,
            value: coupon.shippingDiscountType,
        }) }}

        {{ forms.textField({
            label: "Shipping discount amount"|t('coupons'),
            instructions: "The discount amount to apply to shipping methods"|t('coupons'),
            id: 'shippingDiscountAmount',
            name: 'shippingDiscountAmount',
            value: coupon.shippingDiscountAmount,
            type: 'number',
            errors: coupon.getErrors('shippingDiscountAmount'),
            tip: "Leaving this blank will disable shipping discounts"|t('coupons'),
        }) }}

        {{ forms.selectField({
            label: "Apply to shipping method"|t('coupons'),
            instructions: "Apply a discount to the selected shipping method"|t('coupons'),
            id: 'applyShipping',
            name: 'applyShipping',
            options: applyShipping,
            value: coupon.applyShipping,
        }) }}

        <input type="submit" class="hidden">
    </form>
{% endset %}
