{% import '_includes/forms.twig' as forms %}

<div class="advanced-discount-panel{{ not panel.enabled ? ' is-disabled is-collapsed' }}" data-panel>
    <div class="advanced-discount-panel-header">
        <a class="move icon" title="{{ 'Reorder'|t('app') }}"></a>
        <span class="advanced-discount-panel-title">{{ panel.name }}</span>
        <div class="advanced-discount-panel-actions">
            {{ forms.lightswitch({
                name: 'panels[' ~ panel.key ~ '][enabled]',
                on: panel.enabled,
                small: true,
            }) }}
            <button type="button" class="btn small advanced-discount-panel-collapse" data-panel-collapse>{{ 'Collapse'|t('app') }}</button>
            <button type="button" class="delete icon" data-panel-delete title="{{ 'Delete'|t('app') }}"></button>
        </div>
    </div>

    <div class="advanced-discount-panel-body">
        {{ forms.textField({
            label: 'Discount Name'|t('advanced-discounts'),
            instructions: 'Overrides the discount name shown on the order for this group.'|t('advanced-discounts'),
            name: 'panels[' ~ panel.key ~ '][name]',
            value: panel.name,
        }) }}

        {% set cartCondition %}
            {{ panel.cartCondition.getBuilderHtml()|raw }}
        {% endset %}

        {{ forms.field({
            label: 'Cart Conditions'|t('advanced-discounts'),
            instructions: 'Rules that decide when this group applies.'|t('advanced-discounts'),
        }, cartCondition) }}

        {% set cartActionCondition %}
            <div class="{{ bundle ? 'advanced-discount-bundle' }}">
                {{ panel.cartActionCondition.getBuilderHtml()|raw }}
                {% set nonPromotableVariants = panel.nonPromotableVariants %}
                {% if nonPromotableVariants|length %}
                    <button type="button" class="btn small advanced-discount-excluded-trigger" data-icon="alert">
                        {{ nonPromotableVariants|length == 1
                            ? '1 variant not promotable'|t('advanced-discounts')
                            : '{count} variants not promotable'|t('advanced-discounts', { count: nonPromotableVariants|length }) }}
                    </button>
                    <div class="advanced-discount-excluded-list hidden">
                        <h2>{{ 'Not promotable'|t('advanced-discounts') }}</h2>
                        <p class="light">{{ 'These selected variants will not be discounted.'|t('advanced-discounts') }}</p>
                        <ul>
                            {% for variant in nonPromotableVariants %}
                                <li><a href="{{ variant.product.cpEditUrl }}" target="_blank">{{ variant.sku }} {{ variant.title }}</a></li>
                            {% endfor %}
                        </ul>
                    </div>
                {% endif %}
            </div>
        {% endset %}

        {{ forms.field({
            label: actionLabel,
            instructions: actionInstructions,
        }, cartActionCondition) }}

        {% set messageCondition %}
            {{ panel.messageCondition.getBuilderHtml()|raw }}
        {% endset %}

        {{ forms.field({
            label: 'Messages'|t('advanced-discounts'),
            instructions: 'Shown to customers when they match certain conditions.'|t('advanced-discounts'),
        }, messageCondition) }}

        {{ forms.lightswitchField({
            label: 'Stop Processing Further Groups'|t('advanced-discounts'),
            instructions: 'When this group applies, skip the groups below it.'|t('advanced-discounts'),
            name: 'panels[' ~ panel.key ~ '][stopProcessing]',
            on: panel.stopProcessing,
        }) }}
    </div>
</div>
