{
    "name": "fostercommerce/craft-coupons",
    "description": "Craft coupons",
    "type": "craft-plugin",
    "license": "proprietary",
    "support": {
        "email": "support@fostercommerce.com"
    },
    "require": {
        "php": ">=8.1",
        "craftcms/cms": "^4.6.0"
    },
    "require-dev": {
        "craftcms/ecs": "dev-main",
        "craftcms/phpstan": "dev-main"
    },
    "autoload": {
        "psr-4": {
            "fostercommerce\\coupons\\": "src/"
        }
    },
    "extra": {
        "handle": "coupons",
        "name": "Coupons",
        "developer": "Foster Commerce",
        "documentationUrl": ""
    },
    "scripts": {
        "check-cs": "ecs check --ansi",
        "fix-cs": "ecs check --ansi --fix",
        "phpstan": "phpstan --memory-limit=1G"
    },
    "config": {
        "sort-packages": true,
        "platform": {
            "php": "8.0.2"
        },
        "allow-plugins": {
            "yiisoft/yii2-composer": true,
            "craftcms/plugin-installer": true
        }
    }
}

